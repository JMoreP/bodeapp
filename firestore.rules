rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Function to check if user is Super Admin
    function isSuperAdmin() {
      return request.auth != null && request.auth.uid == 'gDsYzOxufdV3KpoD3dwivVu5sM03';
    }

    // Global Users collection (For Super Admin listing and users to self-register)
    match /global/users/list/{userId} {
      allow read: if isSuperAdmin();
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update, delete: if isSuperAdmin();
    }

    // Tenants structure
    match /tenants/{tenantId} {
      // Allow read to self or SuperAdmin
      allow read: if isSuperAdmin() || (request.auth != null && request.auth.uid == tenantId);
      
      // Allow self-create when registering
      allow create: if request.auth != null && request.auth.uid == tenantId && request.resource.data.status == 'active';
      
      // Allow self-update if active, BUT prevent changing the 'status' field (only super admin can change status)
      // We check if the incoming status is the same as the existing status.
      allow update: if isSuperAdmin() || (request.auth != null && request.auth.uid == tenantId && resource.data.status == 'active' && request.resource.data.status == resource.data.status);
      
      // Allow delete only to SuperAdmin
      allow delete: if isSuperAdmin();

      // Rules for all subcollections under the tenant
      match /{document=**} {
        function isTenantActive() {
          return get(/databases/$(database)/documents/tenants/$(tenantId)).data.status == 'active';
        }

        allow read, write: if isSuperAdmin() || 
          (request.auth != null && request.auth.uid == tenantId && isTenantActive());
      }
    }
    
    // Legacy root collections (Deny all for normal users, allow SuperAdmin for migration purposes)
    match /products/{document=**} {
      allow read, write: if isSuperAdmin();
    }
    match /config/{document=**} {
      allow read, write: if isSuperAdmin();
    }
    match /debts/{document=**} {
      allow read, write: if isSuperAdmin();
    }
  }
}
